{
  "name": "routelag-hud",
  "version": "0.1.0",
  "description": "RouteLag HUD Runtime for Fortnite live data and in-game overlay.",
  "main": "dist/main/main.js",
  "private": true,
  "type": "module",
  "author": {
    "name": "RouteLag"
  },
  "productName": "RouteLagHUD",
  "overwolf": {
    "packages": [
      "gep",
      "overlay"
    ]
  },
  "scripts": {
    "dev": "npm run build && ow-electron . --dev-demo",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.preload.json && vite build",
    "build:windows": "npm run build && ow-electron-builder --win --publish=never",
    "package": "npm run build:windows",
    "start": "ow-electron ."
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^7.0.4",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@overwolf/ow-electron": "latest",
    "@overwolf/ow-electron-builder": "latest",
    "@overwolf/ow-electron-packages-types": "^0.0.5",
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/ws": "^8.18.1",
    "electron": "21.1.0",
    "typescript": "~5.8.3"
  },
  "build": {
    "appId": "com.routelag.hud",
    "productName": "RouteLagHUD",
    "asar": true,
    "nodeGypRebuild": false,
    "directories": {
      "output": "build"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "RouteLagHUD-${version}.${ext}"
    }
  }
}

# Zer0 API (formerly RouteLag) — copy to /opt/routelag-server/.env on the Dallas VPS
#
# Env precedence (server/src/config.ts):
#   1. ZER0_*          (preferred for new deploys)
#   2. ROUTELAG_*      (legacy fallback — keep until VPS cutover)
#   3. Safe default
# Example: ZER0_API_PORT=3001 overrides ROUTELAG_API_PORT when both are set.
# Do not remove ROUTELAG_* from live VPS env until ZER0_* is confirmed deployed.
#
ROUTELAG_BETA_MODE=dallas
ROUTELAG_API_HOST=0.0.0.0
ROUTELAG_API_PORT=3001
ROUTELAG_AUTH_SECRET=change-me-before-deploy
ROUTELAG_ADMIN_SECRET=change-me-admin-token
BETA_CODES=ROUTELAG-BETA,SIGMA-BETA,DECKZEE-BETA,WRENCH-BETA,SIGMA-DALLAS,WRENCH-TEST
ROUTELAG_PEER_MODE=wg
ROUTELAG_WG_CONFIG_FILE=/etc/wireguard/wg0.conf
ROUTELAG_PEERS_FILE=/opt/routelag-server/data/peers.json
ROUTELAG_DATA_FILE=/opt/routelag-server/data/routelag-db.json
ROUTELAG_DEFAULT_DNS=1.1.1.1
ROUTELAG_DEFAULT_MTU=1280

# ── Peer lifecycle (trusted private beta) ─────────────────────────────────────
# Absolute max session lifetime. 0 disables absolute max (heartbeat grace can
# still expire sessions). Defends against client crash without /routes/end.
ROUTELAG_PEER_TTL_HOURS=8
# Minutes without heartbeat before a session is treated as abandoned.
# Clients should call POST /api/routes/heartbeat about every 5 minutes.
ROUTELAG_PEER_HEARTBEAT_GRACE_MINUTES=20

# ── Capacity (do not invent higher numbers without measuring the VPS) ─────────
# Assumption: each node /24 from .10 ≈ 245 usable tunnel IPs. Trusted-beta
# defaults stay far below that so headroom remains for ops / emergencies.
ROUTELAG_MAX_PEERS_PER_NODE=50
ROUTELAG_NODE_CAPACITY_HEADROOM=5
ROUTELAG_MAX_CONCURRENT_SESSIONS_PER_USER=1
ROUTELAG_MAX_CONCURRENT_SESSIONS_PER_DEVICE=1

# ── Emergency controls (server-side; no desktop update required) ──────────────
# Boot-time seeds. Live changes: authenticated PUT /api/admin/controls
# (Bearer or x-admin-token = ROUTELAG_ADMIN_SECRET). Persisted to:
ROUTELAG_RUNTIME_CONTROLS_FILE=/opt/routelag-server/data/runtime-controls.json
# ROUTELAG_MAINTENANCE_MODE=false
# ROUTELAG_ROUTING_DISABLED=false
# ROUTELAG_DISABLED_NODE_IDS=
# ROUTELAG_BLOCKED_CLERK_USER_IDS=
# ROUTELAG_BLOCKED_TESTER_IDS=
# ROUTELAG_BLOCKED_INVITE_CODES=
# ROUTELAG_DISABLED_APP_VERSIONS=

# Routing nodes are config-driven (per-node WireGuard settings + route
# targets), not hardcoded or global. Point this at a JSON file containing
# an array of RouteNode objects (see server/data/nodes.example.json for the
# shape and for Dallas + Johannesburg + a disabled Virginia placeholder).
# When this file is missing, the server falls back to its built-in dev
# nodes (Dallas Beta + Johannesburg Beta) defined in src/nodes.ts.
ROUTELAG_NODES_FILE=/opt/routelag-server/data/nodes.json

# Open on VPS: ufw allow 3001/tcp

# ── Paid routing entitlement (required for /api/routes/create) ────────────────
# Invite login alone does NOT grant routing. Clients must exchange a Clerk
# session (or allowlisted internal identity) for a short-lived entitlement token.
ROUTELAG_REQUIRE_ROUTING_ENTITLEMENT=true
ROUTELAG_ENTITLEMENT_TOKEN_TTL_SECONDS=900
ROUTELAG_ENTITLEMENT_CACHE_TTL_MS=60000
ROUTELAG_DEPLOYMENT_ENV=production
# Internal allowlists are ignored when ROUTELAG_DEPLOYMENT_ENV=production.
ROUTELAG_ALLOW_INTERNAL_ROUTING_ENTITLEMENT=false
# ROUTELAG_INTERNAL_ROUTING_USER_IDS=user_xxx,user_yyy
# ROUTELAG_INTERNAL_ROUTING_INVITE_CODES=WRENCH-TEST

# Clerk session verification (routing VPS — secrets stay on the server)
# CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_ISSUER=https://your-instance.clerk.accounts.dev
# CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
# CLERK_SECRET_KEY=sk_test_...   # optional Backend Billing fallback; never ship to desktop
# CLERK_AUTHORIZED_PARTIES=https://your-app-origin

# ── Monitoring hooks (no paid vendor required) ────────────────────────────────
# External uptime: GitHub Actions dallas-beta-monitor + scripts/beta-dallas-monitor.mjs
# Prefer GET /healthz; fall back to /health until Prompt 10 is on Dallas.
# Expect HTTP 200 when accepting work; 503 in maintenance (/healthz).
# Richer counters/host stats: GET /api/admin/status with admin token.
# Host WG/NAT: scripts/03-status.sh on the VPS.
# Alerts: GitHub Issues (dallas-beta-monitor) → WrenchDevelops.
# Optional Discord: set GitHub secret DISCORD_WEBHOOK_URL (never commit webhooks).
# Optional admin metrics in CI: set GitHub secret DALLAS_ADMIN_TOKEN.
# Docs: docs/BETA_MONITORING.md · docs/BETA_INCIDENT_RUNBOOK.md

# ── Local dev defaults below ──────────────────────────────────────────────────
# ROUTELAG_API_HOST=127.0.0.1
# ROUTELAG_API_PORT=8787
# ROUTELAG_INVITE_CODES=BETA-SA-001,BETA-SA-002
# ROUTELAG_PEER_MODE=mock
# ROUTELAG_NODES_FILE=./data/nodes.json
# ROUTELAG_DEPLOYMENT_ENV=development
# ROUTELAG_ALLOW_INTERNAL_ROUTING_ENTITLEMENT=true
# ROUTELAG_INTERNAL_ROUTING_INVITE_CODES=BETA-SA-001

OSIRION_API_BASE_URL=
OSIRION_API_KEY=
OSIRION_WEBHOOK_SECRET=
REPLAY_UPLOAD_MAX_MB=250
REPLAY_STORAGE_DIR=data/replays/uploads
REPLAY_POLL_INTERVAL_MS=30000

# RouteLag Dallas Beta API — copy to /opt/routelag-server/.env on the Dallas VPS
ROUTELAG_BETA_MODE=dallas
ROUTELAG_API_HOST=0.0.0.0
ROUTELAG_API_PORT=3001
ROUTELAG_AUTH_SECRET=change-me-before-deploy
ROUTELAG_ADMIN_SECRET=change-me-admin-token
BETA_CODES=ROUTELAG-BETA,SIGMA-DALLAS,WRENCH-TEST
ROUTELAG_PEER_MODE=wg
ROUTELAG_WG_CONFIG_FILE=/etc/wireguard/wg0.conf
ROUTELAG_PEERS_FILE=/opt/routelag-server/data/peers.json
ROUTELAG_DATA_FILE=/opt/routelag-server/data/routelag-db.json
ROUTELAG_DEFAULT_DNS=1.1.1.1
ROUTELAG_DEFAULT_MTU=1280

# Routing nodes are config-driven (per-node WireGuard settings + route
# targets), not hardcoded or global. Point this at a JSON file containing
# an array of RouteNode objects (see server/data/nodes.example.json for the
# shape and for Dallas + Johannesburg + a disabled Virginia placeholder).
# When this file is missing, the server falls back to its built-in dev
# nodes (Dallas Beta + Johannesburg Beta) defined in src/nodes.ts.
ROUTELAG_NODES_FILE=/opt/routelag-server/data/nodes.json

# Open on VPS: ufw allow 3001/tcp

# ── Local dev defaults below ──────────────────────────────────────────────────
# ROUTELAG_API_HOST=127.0.0.1
# ROUTELAG_API_PORT=8787
# ROUTELAG_INVITE_CODES=BETA-SA-001,BETA-SA-002
# ROUTELAG_PEER_MODE=mock
# ROUTELAG_NODES_FILE=./data/nodes.json

OSIRION_API_BASE_URL=
OSIRION_API_KEY=
OSIRION_WEBHOOK_SECRET=
REPLAY_UPLOAD_MAX_MB=250
REPLAY_STORAGE_DIR=data/replays/uploads
REPLAY_POLL_INTERVAL_MS=30000

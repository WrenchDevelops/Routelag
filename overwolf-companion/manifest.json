{
  "manifest_version": 1,
  "type": "WebApp",
  "meta": {
    "name": "RouteLag HUD Companion",
    "version": "0.1.0",
    "minimum-overwolf-version": "0.265.0",
    "author": "RouteLag",
    "description": "Configurable Fortnite performance HUD powered by RouteLag."
  },
  "data": {
    "game_events": [21216],
    "game_targeting": {
      "type": "dedicated",
      "game_ids": [21216]
    },
    "launch_events": [
      {
        "event": "GameLaunch",
        "event_data": {
          "game_ids": [21216],
          "wait_for_stable_framerate": 30
        },
        "start_minimized": true
      }
    ],
    "hotkeys": {},
    "windows": {
      "background": {
        "file": "background.html",
        "is_background_page": true
      },
      "overlay": {
        "file": "overlay.html",
        "transparent": true,
        "resizable": false,
        "show_in_taskbar": false,
        "clickthrough": true,
        "size": {
          "width": 1920,
          "height": 1080
        }
      },
      "settings": {
        "file": "settings.html",
        "transparent": false,
        "resizable": true,
        "show_in_taskbar": true,
        "size": {
          "width": 480,
          "height": 420
        }
      }
    },
    "start_window": "settings"
  }
}

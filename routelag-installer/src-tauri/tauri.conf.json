{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RouteLag Setup",
  "version": "0.1.4",
  "identifier": "com.routelag.setup",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "RouteLag Setup",
        "width": 900,
        "height": 620,
        "resizable": false,
        "center": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
